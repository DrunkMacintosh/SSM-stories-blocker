<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Permission setup screen -->
    <include
        android:id="@+id/layoutPermissionSetup"
        layout="@layout/layout_permission_setup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Dashboard screen -->
    <LinearLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <Switch
            android:id="@+id/switchMonitoring"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable Protection"
            android:textSize="20sp"
            android:checked="false" />

        <TextView
            android:id="@+id/textProtectionStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Protection: OFF"
            android:textSize="18sp" />

    </LinearLayout>

</FrameLayout>
